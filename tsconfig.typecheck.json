{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "mdx", "dom-chromium-ai", "vitest/globals"]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "e2e/**/*.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "agent"
  ]
}
