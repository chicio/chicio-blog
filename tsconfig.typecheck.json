{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "mdx", "dom-chromium-ai", "vitest/globals", "next/image-types/global"]
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "e2e/**/*.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "agent"
  ]
}
