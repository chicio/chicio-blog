{
    "$schema": "https://unpkg.com/knip@6/schema.json",
    "entry": [
        "src/app/sw.ts",
        "src/content/**/content.mdx",
        "serwist.config.mjs",
        "src/types/component-store.ts",
        "tools/eslint/index.js",
        "tools/eslint/rules/*.js",
        "e2e/**/*.ts"
    ],
    "project": [
        "src/**/*.{ts,tsx,mdx}",
        "tools/**/*.js",
        "e2e/**/*.ts"
    ],
    "mdx": {
        "entry": ["src/content/**/content.mdx"]
    },
    "ignoreDependencies": [
        "tailwindcss",
        "highlight.js",
        "agent-browser"
    ],
    "ignoreExportsUsedInFile": true
}
